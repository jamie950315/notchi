---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-row">
    <span>&copy; {year} <a href="https://skruban.com">Ruban</a></span>
    <div class="footer-links">
      <div class="footer-demo-callout">
        <div class="demo-anchor">
          <span class="demo-note">demo here!</span>
          <a href="https://github.com/sk-ruban/notchi" class="demo-link">
            <span class="demo-link-text" data-demo-circle>GitHub</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  import { annotate } from 'rough-notation';

  function initDemoCallout() {
    const target = document.querySelector('[data-demo-circle]');
    if (!(target instanceof HTMLElement)) return;

    if (target.dataset.demoAnnotated === 'true') return;

    target.dataset.demoAnnotated = 'true';

    const annotation = annotate(target, {
      type: 'circle',
      color: '#e78b57',
      strokeWidth: 1.9,
      padding: 6,
      iterations: 2,
      animationDuration: 900,
      multiline: false,
    });

    requestAnimationFrame(() => annotation.show());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemoCallout, { once: true });
  } else {
    initDemoCallout();
  }
</script>
